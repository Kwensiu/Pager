{
  "extends": "./tsconfig.web.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": false,
    "outDir": "out/jest-test-dist",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["jest", "node"],
    "declaration": false,
    "declarationMap": false,
    "incremental": false
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx"
  ],
  "exclude": ["node_modules", "out", "dist"]
}
